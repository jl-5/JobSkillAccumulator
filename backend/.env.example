# Required: get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Country is chosen per-search from the app's UI dropdown (defaults to US).

# Optional: adds a Google Custom Search source that finds postings on 15
# different ATS job boards indexed by Google (similar to what
# briansjobsearch.com does with "site:" search-engine queries), then fetches
# each posting page for its full description. See README.md for the full
# list of sites and why each was (or wasn't) included.
#   1. console.cloud.google.com -> enable "Custom Search API" -> create an API key
#   2. programmablesearchengine.google.com -> create a search engine ->
#      under "Sites to search" add each of these:
#        greenhouse.io/*                jobs.jobvite.com/*
#        jobs.lever.co/*                jobappnetwork.com/*
#        recruitee.com/*                breezy.hr/*
#        jobs.smartrecruiters.com/*     applytojob.com/*
#        recruiting.paylocity.com/*
#        jobs.gusto.com/*
#        jobs.personio.com/*
#        catsone.com/*
#        trinethire.com/*
#        teamtailor.com/*
#        pinpointhq.com/*
#      (greenhouse.io is intentionally the bare domain, not a specific
#      subdomain - Greenhouse has hosted postings at boards.greenhouse.io,
#      job-boards.greenhouse.io, and job-boards.eu.greenhouse.io at
#      different times, and the bare domain covers all of them, current and
#      future. whole-web search was discontinued for new engines in Jan
#      2026, so site-restricted search is required now - the app's own
#      query also restricts to just these domains, so the search engine
#      itself can technically be broader, but scoping it here avoids
#      surprises) -> copy its Search engine ID (cx)
# Free tier is 100 queries/day. Leave blank to skip this source.
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Optional: alternative to the Google source above - same 15 ATS domains,
# same "site:" search + full-page-fetch approach, but via the Brave Search
# API instead of Google Custom Search. Simpler signup (no Cloud project/API-
# enablement dance), but still requires a credit card on file for identity
# verification (not charged unless you exceed the $5/month free credit).
#   1. search.brave.com/api -> sign up, pick the free "Search" plan
#   2. Dashboard -> API Keys -> create a key
# Only set ONE of GOOGLE_CSE_API_KEY/GOOGLE_CSE_ID or BRAVE_SEARCH_API_KEY -
# both search the identical domain list, so running both fetches the same
# postings twice under two different source names.
BRAVE_SEARCH_API_KEY=

OUTPUT_DIR=output
CORS_ORIGIN=http://localhost:5173
